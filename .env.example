# Server
SERVER_PORT=8080

# Database (MySQL)
DB_URL=jdbc:mysql://localhost:3306/deokgil
DB_USERNAME=root
DB_PASSWORD=

# JPA
DDL_AUTO=validate
JPA_FORMAT_SQL=true
JPA_SHOW_SQL=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OAuth2 - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# AWS S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRATION=1800000      # 30 min - keep access tokens short-lived
JWT_REFRESH_EXPIRATION=1209600000  # 14 days - carried only in the HttpOnly refresh cookie

# Refresh Token Cookie
COOKIE_SECURE=true                 # must be true in production (HTTPS only); set false for local http dev
COOKIE_SAME_SITE=Strict            # Strict | Lax | None (None requires Secure=true)
COOKIE_DOMAIN=                     # leave empty to scope the cookie to the current host

# Claude AI API
CLAUDE_API_KEY=

# Kakao Local API (주소 -> 좌표 변환)
KAKAO_API_KEY=

# 기상청 단기예보 조회서비스 (공공데이터포털 https://www.data.go.kr 발급 서비스키, URL 인코딩된 값 그대로 붙여넣을 것)
WEATHER_API_KEY=

# Firebase Cloud Messaging (푸시 알림) - Firebase 콘솔 > 프로젝트 설정 > 서비스 계정에서 발급받은
# JSON 키 파일을 로컬에 저장하고 그 경로를 적을 것. 이 파일 자체는 절대 커밋하지 말 것(.gitignore 확인)
FIREBASE_CREDENTIALS_PATH=

# 행사장 위경도(Event/Schedule.latitude/longitude) 컬럼 암호화 키.
# 생성: openssl rand -base64 32   (이 키를 잃어버리면 저장된 좌표는 복구 불가능하니 별도 보관할 것)
LOCATION_ENCRYPTION_KEY=

# CORS 허용 origin (콤마로 구분, 공백 없이). 배포 도메인이 정해지면 뒤에 추가할 것
# 예: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://deokgil.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Swagger / OpenAPI
SWAGGER_ENABLED=true               # 운영 배포 시 반드시 false 로 설정

# Logging
LOG_LEVEL=INFO
HIBERNATE_SQL_LOG_LEVEL=INFO
HIBERNATE_BIND_LOG_LEVEL=INFO
